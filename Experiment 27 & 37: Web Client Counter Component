<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html>
<head>
    <title>Global Traffic Client Analytics Counter</title>
</head>
<body>
    <h2>Application Traffic Tracker Dashboard</h2>
    <%
        Integer clientHits = (Integer) application.getAttribute("globalCounter");
        if(clientHits == null) {
            clientHits = 1;
        } else {
            clientHits += 1;
        }
        application.setAttribute("globalCounter", clientHits);
    %>
    <p>Total page requests captured across this environment session: <strong><%= clientHits %></strong></p>
</body>
</html>
