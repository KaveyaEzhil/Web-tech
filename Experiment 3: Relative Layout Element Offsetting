<!DOCTYPE html>
<html lang="en">
<head>
    <style>
        .base-box {
            width: 200px;
            height: 100px;
            background-color: lightblue;
            border: 2px solid blue;
        }
        .offset-box {
            position: relative;
            top: 25px;
            left: 50px;
            background-color: lightcoral;
            border: 2px solid red;
        }
    </style>
</head>
<body>
    <div class="base-box">Static Box (Normal Flow)</div>
    <div class="base-box offset-box">Relative Offset Box</div>
</body>
</html>
